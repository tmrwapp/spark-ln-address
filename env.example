# MySQL Docker container credentials (used by docker-compose.prod.yml)
# Use strong, unique passwords for production
MYSQL_ROOT_PASSWORD="your_strong_root_password"
MYSQL_PASSWORD="your_strong_password"

# Database connection (for Docker MySQL) - uses MYSQL_PASSWORD variable to avoid defining password twice
DATABASE_URL="mysql://spark_user:${MYSQL_PASSWORD}@localhost:3306/spark_ln_address"

# Public API URL (must match your domain)
PUBLIC_BASE_URL="https://yourdomain.com"

# Port (default: 3003)
PORT=3003