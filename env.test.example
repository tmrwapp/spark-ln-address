# Test Database Configuration
# This file is optional - the test setup will use these defaults if .env.test doesn't exist
DATABASE_URL="mysql://spark_user:spark_password@localhost:3309/spark_ln_address_test"

# Public API Configuration
PUBLIC_BASE_URL="http://localhost:3003"

# Lightspark SDK (test values)
LIGHTSPARK_CLIENT_ID="test_client_id"
LIGHTSPARK_CLIENT_SECRET="test_client_secret"
LIGHTSPARK_NODE_ID="test_node_id"

# Optional
PORT=3003
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

